# National Examination Board - Clean URL Engine
RewriteEngine On

# 1. Specific Page Aliases
RewriteRule ^franchise-info$ franchise/franchise-information.php [L]

# 2. Redirect index.php to root /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(?:index\.php)?\s [NC]
RewriteRule ^index\.php$ ./ [R=301,L]

# 3. Force remove .php from all requests (Permanent Redirect)
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php [NC]
RewriteRule ^(.+)\.php$ $1 [R=301,L]

# 4. Skip rewrites for real files (images, css, js) and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 5. Map clean URLs to .php files if they exist on disk
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# 6. Route details pages with IDs (e.g., /event-details/12)
RewriteRule ^([a-zA-Z0-9_-]+)/([0-9]+)/?$ page.php?slug=$1&id=$2 [L,QSA]

# 7. Route all other clean slugs to universal page renderer
# Skip admin/student/franchise etc. for the catch-all slug route
RewriteCond %{REQUEST_URI} !^/(admin|student|franchise|ajax|includes|common|scratch|assets|media) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)/?$ page.php?slug=$1 [L,QSA]


# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
